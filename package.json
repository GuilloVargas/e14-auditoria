{
  "name": "audit-e-14",
  "version": "1.0.0",
  "description": "App local para inventariar, descargar y auditar metadatos de formularios E14 publicados por la Registraduria.",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "node server.mjs",
    "desktop": "node electron/run-desktop.cjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "inventory": "node scripts/e14-audit.mjs inventory",
    "download": "node scripts/e14-audit.mjs download",
    "check": "node --check server.mjs && node --check scripts/e14-audit.mjs && node --check electron/main.mjs && node --check electron/preload.cjs && node --check electron/run-desktop.cjs && node --check public/app.js"
  },
  "keywords": [],
  "author": "Caxvalencia <caxvalencia@gmail.com>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "exiftool-vendored": "36.0.0",
    "pdf-lib": "1.17.1"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "co.local.audit-e14",
    "productName": "Auditoria E14",
    "asarUnpack": [
      "node_modules/exiftool-vendored.*/**/*"
    ],
    "files": [
      "electron/**",
      "public/**",
      "scripts/**",
      "build/icon.png",
      "server.mjs",
      "package.json",
      "!output/**",
      "!.playwright-cli/**",
      "!.playwright-mcp/**",
      "!playwright-report/**",
      "!test-results/**",
      "!*.log"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "Auditoria.E14-mac.dmg"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Auditoria.E14.Setup.exe"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "artifactName": "Auditoria.E14.AppImage"
        },
        {
          "target": "deb",
          "artifactName": "audit-e-14_amd64.deb"
        }
      ],
      "category": "Utility"
    }
  }
}
